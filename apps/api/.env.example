# ─────────────────────────────────────────────────────────
# AcademIQ API — Environment Variables
# Copy to .env and fill in your actual values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────

# Environment
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database (Supabase PostgreSQL)
# Get from: Supabase → Project Settings → Database → Connection string
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Auth (Clerk)
# Get from: clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# AI Providers (use at least one)
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_PROVIDER=groq

# Vector DB (Qdrant)
# Local: http://localhost:6333 / Cloud: get from cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Cache (Redis / Upstash)
# Local: redis://localhost:6379 / Upstash: get from upstash.com
REDIS_URL=redis://localhost:6379

# File Storage (S3 / Cloudflare R2)
S3_BUCKET_NAME=academiq-documents
S3_ENDPOINT_URL=        # Leave empty for AWS; set for R2: https://[account-id].r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# LangSmith (optional — for agent observability)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=academiq
